{
    "name": "survos/kit-bundle",
    "description": "Base classes and traits for consistent Survos bundle development — auto-registers twig namespaces, asset mapper paths, and doctrine mappings by convention",
    "keywords": ["symfony", "bundle", "base-class", "traits"],
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": "^8.5",
        "symfony/config": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/http-kernel": "^8.1"
    },
    "require-dev": {
        "doctrine/orm": "^3.0",
        "symfony/asset-mapper": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/twig-bundle": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Survos\\Kit\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.1-dev"
        }
    }
}
